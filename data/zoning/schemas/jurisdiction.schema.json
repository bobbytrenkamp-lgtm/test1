{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "zoning/jurisdiction",
  "title": "Zoning Jurisdiction",
  "description": "Describes a single zoning jurisdiction — the controlling authority for a geographic area.",
  "type": "object",
  "required": ["jurisdiction_id", "jurisdiction_name", "jurisdiction_type", "state", "verification_status"],
  "properties": {
    "jurisdiction_id":                 { "type": "string", "description": "Stable ID, e.g. va-loudoun-county" },
    "jurisdiction_name":               { "type": "string" },
    "jurisdiction_type":               { "type": "string", "enum": ["county", "city", "town", "village", "township", "parish", "borough", "consolidated_government", "special_planning_jurisdiction"] },
    "state":                           { "type": "string", "description": "2-letter abbreviation" },
    "state_fips":                      { "type": "string", "description": "2-digit FIPS" },
    "county":                          { "type": "string" },
    "county_fips":                     { "type": "string", "description": "5-digit FIPS (state+county)" },
    "municipality":                    { "type": ["string", "null"] },
    "controlling_authority":           { "type": "string", "description": "Which government body controls zoning" },
    "official_planning_department_name": { "type": "string" },
    "official_zoning_page_url":        { "type": ["string", "null"], "format": "uri" },
    "official_zoning_map_url":         { "type": ["string", "null"], "format": "uri" },
    "official_ordinance_url":          { "type": ["string", "null"], "format": "uri" },
    "official_code_provider":          { "type": ["string", "null"] },
    "gis_service_url":                 { "type": ["string", "null"], "format": "uri" },
    "open_data_portal_url":            { "type": ["string", "null"], "format": "uri" },
    "parcel_source_url":               { "type": ["string", "null"], "format": "uri" },
    "source_license":                  { "type": ["string", "null"] },
    "retrieval_method":                { "type": "string", "enum": ["arcgis_featureserver", "arcgis_mapserver", "geojson_download", "shapefile_download", "manual", "not_attempted"] },
    "source_last_updated":             { "type": ["string", "null"] },
    "source_last_checked":             { "type": ["string", "null"] },
    "ordinance_effective_date":        { "type": ["string", "null"] },
    "ordinance_version":               { "type": ["string", "null"] },
    "data_coverage_status":            { "type": "string", "enum": ["complete", "partial", "minimal", "none", "unknown"] },
    "geometry_coverage_status":        { "type": "string", "enum": ["complete", "partial", "demo_only", "none"] },
    "dimensional_standard_coverage":   { "type": "string", "enum": ["complete", "partial", "minimal", "none"] },
    "permitted_use_coverage":          { "type": "string", "enum": ["complete", "partial", "minimal", "none"] },
    "overlay_coverage":                { "type": "string", "enum": ["complete", "partial", "minimal", "none"] },
    "verification_status":             { "type": "string", "enum": ["verified", "high_confidence", "moderate_confidence", "low_confidence", "unverified", "unavailable"] },
    "data_center_relevance":           { "type": "string", "enum": ["critical", "high", "medium", "low"] },
    "pilot_notes":                     { "type": ["string", "null"] },
    "known_limitations":               { "type": "array", "items": { "type": "string" } },
    "notes":                           { "type": ["string", "null"] }
  }
}
